# Server
PORT=3000

# Boce API credentials
# Get your key from https://www.boce.com/api.html
BOCE_API_URL=https://api.boce.com/v3
BOCE_API_KEY=5da3e44ad95f3b64178d7e55cf579e0c

# Which Boce nodes to include (comma-separated node IDs)
# Get the full list from:  GET https://api.boce.com/v3/node/list?key=YOUR_KEY
# Leave this as the default or add more from the list
BOCE_NODE_IDS=6,31,32

# Boce request config
BOCE_TIMEOUT_SECONDS=15
BOCE_POLL_INTERVAL_SECONDS=10
BOCE_POLL_TIMEOUT_SECONDS=120
